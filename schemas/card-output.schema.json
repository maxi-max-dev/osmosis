{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "concept_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "concept_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "lesson": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "options": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "correct_index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "explanation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  },
  "required": [
    "concept_id",
    "concept_name",
    "lesson",
    "question",
    "options",
    "correct_index",
    "explanation"
  ]
}
