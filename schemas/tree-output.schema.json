{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 12,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "concept_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "concept_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "parent_id": {
            "type": ["string", "null"],
            "maxLength": 80
          }
        },
        "required": ["concept_id", "concept_name", "parent_id"]
      }
    }
  },
  "required": ["nodes"]
}
